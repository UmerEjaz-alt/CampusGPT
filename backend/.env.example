# ============================================================
#  CampusGPT Backend — Environment Variables
#  Copy to .env and fill in your values
#  NEVER commit .env to GitHub
# ============================================================

# Node environment
NODE_ENV=development

# Server port
PORT=5000

# MongoDB Atlas connection string
# Get from: https://cloud.mongodb.com → Connect → Drivers
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/campusgpt?retryWrites=true&w=majority

# JWT Secret — use a long random string (min 32 chars)
# Generate one: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-long

# Groq API key (free at https://console.groq.com)
GROQ_API_KEY=gsk_your_groq_key_here

# Frontend URL (for CORS)
# Development:
FRONTEND_URL=http://localhost:3000
# Production (replace with your Vercel URL):
# FRONTEND_URL=https://campusgpt.vercel.app
